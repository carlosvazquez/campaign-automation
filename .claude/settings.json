{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "permissions": {
        "defaultMode": "acceptEdits",
        "allow": [
            "Bash(npm install*)",
            "Bash(npm run dev*)",
            "Bash(npm run build*)",
            "Bash(npm run lint*)",
            "Bash(npm run test*)",
            "Bash(npm test*)",
            "Bash(npx tsc*)",
            "Bash(npx vitest*)",
            "Bash(git status)",
            "Bash(git diff*)",
            "Bash(git add*)",
            "Bash(git commit*)",
            "Bash(git log*)",
            "Bash(mkdir -p*)",
            "Bash(touch*)",
            "Bash(cd*)",
            "Bash(ls*)",
            "Bash(cat*)",
            "Read(**)",
            "Edit(**)",
            "Write(**)"
        ],
        "deny": [
            "Bash(rm -rf*)",
            "Bash(git push --force*)",
            "Bash(sudo*)",
            "Bash(curl*)",
            "Bash(wget*)",
            "Read(.env)",
            "Read(.env.local)",
            "Read(.env.*)",
            "Edit(.env)",
            "Edit(.env.local)",
            "Edit(.env.*)"
        ]
    },
    "env": {
        "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1"
    }
}
